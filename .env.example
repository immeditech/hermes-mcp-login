# hermes-mcp-login — environment template. Copy to .env (gitignored) or set in
# the systemd unit. Per-MCP-server settings live in the agent's config.yaml.

# Externally reachable base URL (TLS-terminated by your reverse proxy). The
# OAuth redirect_uri is derived as <PUBLIC_BASE>/mcp/<name>/callback and must be
# registered as a Valid Redirect URI at the IdP. REQUIRED to start a login.
HERMES_MCP_LOGIN_PUBLIC_BASE=https://samuel.hermes.immeditech.ch

# Bind address. Use loopback (127.0.0.1) only if the reverse proxy runs on the
# SAME host. If the proxy is on another host (e.g. a central HAProxy), bind a
# routable interface (0.0.0.0 or the host IP) and firewall the port so only the
# proxy can reach it — otherwise the proxy gets "connection refused".
HERMES_MCP_LOGIN_HOST=0.0.0.0
HERMES_MCP_LOGIN_PORT=9120

# Seconds a human may take in the browser before the flow is abandoned.
HERMES_MCP_LOGIN_CALLBACK_TIMEOUT=300

# Seconds /login waits for the IdP authorize URL (discovery round-trip).
HERMES_MCP_LOGIN_AUTHORIZE_TIMEOUT=30

# Optional "restart agent gateway" button. Off by default; needs a sudoers rule
# permitting the configured command. The default is a robust full restart via
# systemctl. Alternative: "sudo -n hermes gateway restart --system" (Hermes'
# graceful drain + unit refresh) — but that needs HERMES_HOME preserved through
# sudo (env_keep), so systemctl is the simpler default.
# HERMES_MCP_LOGIN_GATEWAY_RESTART=true
# HERMES_MCP_LOGIN_GATEWAY_RESTART_CMD=sudo -n systemctl restart hermes-gateway.service
# HERMES_MCP_LOGIN_GATEWAY_RESTART_TIMEOUT=30

# Which Hermes profile's config + token store to use (defaults to ~/.hermes).
# HERMES_HOME=/home/hermes/.hermes
